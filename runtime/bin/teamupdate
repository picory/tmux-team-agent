#!/usr/bin/env bash
set -euo pipefail

RUNTIME_HOME="${TMUX_RUNTIME_HOME:-$HOME/.tmux-runtime}"

# First arg is project-dir only if it doesn't start with '--'
if [[ "${1:-}" == --* ]] || [[ -z "${1:-}" ]]; then
    python3 "$RUNTIME_HOME/lib/runtime.py" update --project-dir "$PWD" "$@"
else
    python3 "$RUNTIME_HOME/lib/runtime.py" update --project-dir "$1" "${@:2}"
fi
