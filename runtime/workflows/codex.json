    {
      "id": "completion-report",
      "name": "Codex 검수 완료 보고서",
      "role": "product-manager",
      "title_template": "[{task}] Codex 검수 완료 보고서 작성",
      "scope": "docs",
      "depends_on": ["codex-final-review"],
      "policy": {"auto_review": false, "auto_qa": false, "auto_docs": false}
