      "role": "test-harness-engineer",
      "title_template": "[{task}][Codex] 최종 검수 진행",
      "scope": "review",
      "depends_on": ["security"],
      "policy": {"auto_review": false, "auto_qa": false, "auto_docs": false},
      "metadata": {"uses_codex": true, "codex_mode": "final-review"}
